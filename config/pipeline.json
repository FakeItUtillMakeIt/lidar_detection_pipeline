{
    "pipeline": {
        "id": "lidar_detection_pipeline"
    },
    "nodes": [
        {
            "id": "source",
            "type": "bin_source",
            "params": {
                "input_path": "../data",
                "input_type": "bin"
            }
        },
        {
            "id": "infer",
            "type": "detection_infer",
            "params": {
                "model_path": "../model/pointpillar.plan",
                "score_thresh": 0.1,
                "nms_thresh": 0.01
            }
        },
        {
            "id": "tracker",
            "type": "tracker",
            "params": {
                "tracker_type": "ocsort",
                "ocsort_config": {
                    "det_thresh": 0.1,
                    "max_age": 30,
                    "min_hits": 3,
                    "iou_threshold": 0.3,
                    "delta_t": 3,
                    "inertia": 0.2,
                    "use_byte": false
                }
            }
        },
        {
            "id": "attribute",
            "type": "attribute",
            "params": {
                "dt": 0.1
            }
        },
        {
            "id": "planner",
            "type": "potential_field_planner",
            "params": {
                "use_relative_frame": true,
                "max_speed": 8.0,
                "max_accel": 2.0,
                "planning_horizon": 5.0,
                "planning_resolution": 0.1,
                "max_planning_points": 200,
                "obstacle_inflation": 0.5,
                "safety_margin": 1.0,
                "attractive_gain": 1.0,
                "repulsive_gain": 10.0,
                "obstacle_influence_dist": 5.0,
                "enable_boundary": true,
                "boundary_left": 3.75,
                "boundary_right": -3.75,
                "boundary_start_x": 0.0,
                "boundary_end_x": 200.0,
                "boundary_inflation": 0.3,
                "boundary_repulsive_gain": 50.0,
                "boundary_influence_dist": 2.0,
                "goal_x": 100.0,
                "goal_y": 0.0,
                "enable_control": true,
                "control_frequency": 10.0
            }
        },
        {
            "id": "file_output",
            "type": "file_output",
            "params": {
                "output_dir": "./out",
                "output_type": "file"
            }
        },
        {
            "id": "bev_vis",
            "type": "bev_visualizer",
            "params": {
                "output_dir": "./out/bev"
            }
        },
        {
            "id": "traj_vis",
            "type": "trajectory_visualizer",
            "params": {
                "output_dir": "./out/trajectory"
            }
        },
        {
            "id": "controller",
            "type": "pid_controller",
            "params": {
                "controller_type": "pid",
                "kp_speed": 1.0,
                "ki_speed": 0.1,
                "kd_speed": 0.05,
                "kp_heading": 1.0,
                "ki_heading": 0.0,
                "kd_heading": 0.1,
                "kp_lateral": 0.5,
                "ki_lateral": 0.0,
                "kd_lateral": 0.05,
                "max_integral": 1.0,
                "dt": 0.1
            }
        }
    ],
    "edges": [
        {"from": "source", "to": "infer"},
        {"from": "infer", "to": "tracker"},
        {"from": "tracker", "to": "attribute"},
        {"from": "attribute", "to": "planner"},
        {"from": "attribute", "to": "file_output"},
        {"from": "attribute", "to": "bev_vis"},
        {"from": "planner", "to": "traj_vis"},
        {"from": "planner", "to": "controller"}
    ]
}
