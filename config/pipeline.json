{
    "pipeline": {
        "id": "lidar_detection_pipeline"
    },
    "nodes": [
        {
            "id": "source",
            "type": "bin_source",
            "params": {
                "input_path": "../data",
                "input_type": "bin"
            }
        },
        {
            "id": "infer",
            "type": "detection_infer",
            "params": {
                "model_path": "../model/pointpillar.plan",
                "score_thresh": 0.1,
                "nms_thresh": 0.01
            }
        },
        {
            "id": "tracker",
            "type": "tracker",
            "params": {
                "tracker_type": "ocsort",
                "ocsort_config": {
                    "det_thresh": 0.3,
                    "max_age": 30,
                    "min_hits": 3,
                    "iou_threshold": 0.3,
                    "delta_t": 3,
                    "inertia": 0.2,
                    "use_byte": false
                }
            }
        },
        {
            "id": "attribute",
            "type": "attribute",
            "params": {
                "dt": 0.1
            }
        },
        {
            "id": "file_output",
            "type": "file_output",
            "params": {
                "output_dir": "./out",
                "output_type": "file"
            }
        },
        {
            "id": "bev_vis",
            "type": "bev_visualizer",
            "params": {
                "output_dir": "./out/bev"
            }
        }
    ],
    "edges": [
        {"from": "source", "to": "infer"},
        {"from": "infer", "to": "tracker"},
        {"from": "tracker", "to": "attribute"},
        {"from": "infer", "to": "file_output"},
        {"from": "infer", "to": "bev_vis"}
    ]
}
